<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Your Order Has Been Delivered</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}body{background:#f0f2f5;font-family:'Segoe UI',Arial,sans-serif}.wrapper{max-width:600px;margin:40px auto;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.08)}.header{background:#198754;padding:28px 40px;text-align:center}.header h1{color:#fff;font-size:1.1rem;font-weight:700;letter-spacing:2px}.body{padding:40px}.greeting{font-size:1rem;color:#0d1f4f;font-weight:600;margin-bottom:12px}.text{font-size:.92rem;color:#555;line-height:1.7;margin-bottom:20px}.tracking{text-align:center;background:#0d1f4f;color:#fff;border-radius:12px;padding:20px;margin-bottom:24px}.tracking-label{font-size:.78rem;text-transform:uppercase;letter-spacing:2px;color:rgba(255,255,255,.6);margin-bottom:6px}.tracking-number{font-size:1.6rem;font-weight:800;color:#e8610a;letter-spacing:3px}.success-icon{text-align:center;margin-bottom:24px}.success-circle{width:80px;height:80px;background:#d1e7dd;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:2.2rem}.info-box{background:#f4f6fb;border-radius:12px;padding:20px 24px;margin-bottom:20px}.info-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #e8edf7;font-size:.88rem}.info-row:last-child{border-bottom:none}.info-label{color:#888}.info-value{color:#0d1f4f;font-weight:600}.btn{display:inline-block;background:#198754;color:#fff;text-decoration:none;padding:12px 32px;border-radius:8px;font-weight:700;font-size:.95rem}.btn-outline{display:inline-block;background:transparent;color:#0d1f4f;text-decoration:none;padding:12px 32px;border-radius:8px;font-weight:700;font-size:.95rem;border:2px solid #0d1f4f;margin-left:12px}.divider{height:1px;background:#eee;margin:28px 0}.footer{background:#f4f6fb;padding:24px 40px;text-align:center}.footer p{font-size:.8rem;color:#aaa;line-height:1.6}.footer a{color:#e8610a;text-decoration:none}
</style>
</head>
<body>
<div class="wrapper">
    <div class="header"><h1>LOVELISTICS</h1></div>
    <div class="body">
        <p class="greeting">Hi <%= fullName %>,</p>

        <div class="success-icon">
            <div class="success-circle">✅</div>
        </div>

        <p class="text" style="text-align:center;font-size:1rem;font-weight:700;color:#0d1f4f;">
            Your package has been delivered!
        </p>
        <p class="text" style="text-align:center;">
            Please confirm receipt in the app to complete the delivery.
        </p>

        <div class="tracking">
            <p class="tracking-label">Tracking Number</p>
            <p class="tracking-number">#<%= trackingNumber %></p>
        </div>

        <div class="info-box">
            <div class="info-row">
                <span class="info-label">Delivered To</span>
                <span class="info-value"><%= deliveryAddress %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Driver</span>
                <span class="info-value"><%= driverName %></span>
            </div>
            <div class="info-row">
                <span class="info-label">Delivery Fee</span>
                <span class="info-value" style="color:#e8610a;">&#8358;<%= price %></span>
            </div>
        </div>

        <div style="text-align:center;margin-bottom:20px;">
            <a href="<%= orderUrl %>" class="btn">Confirm Receipt →</a>
        </div>

        <div class="divider"></div>
        <p class="text" style="font-size:.82rem;">
            Thank you for choosing LOVELISTICS. We hope your delivery was smooth and on time!
        </p>
    </div>
    <div class="footer">
        <p>Need help? <a href="mailto:support@lovelistics.com">support@lovelistics.com</a><br/>© 2026 LOVELISTICS. All rights reserved.</p>
    </div>
</div>
</body>
</html>